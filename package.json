{
  "name": "edushift-front",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --configuration development --proxy-config proxy.conf.mjs",
    "start:prod": "ng serve --configuration production",
    "build": "ng build",
    "build:dev": "ng build --configuration development",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadlessCI --code-coverage=true",
    "lint": "ng lint --max-warnings 0",
    "lint:fix": "ng lint --fix",
    "format": "prettier --write \"src/**/*.{ts,html,scss,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,json,md}\"",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report playwright-report",
    "e2e:install": "playwright install --with-deps chromium",
    "lhci": "lhci autorun"
  },
  "private": true,
  "dependencies": {
    "@abacritt/angularx-social-login": "^2.4.0",
    "@angular/animations": "~19.2.19",
    "@angular/cdk": "~19.2.19",
    "@angular/common": "~19.2.19",
    "@angular/compiler": "~19.2.19",
    "@angular/core": "~19.2.19",
    "@angular/forms": "~19.2.19",
    "@angular/platform-browser": "~19.2.19",
    "@angular/platform-browser-dynamic": "~19.2.19",
    "@angular/router": "~19.2.19",
    "@stomp/stompjs": "^7.0.0",
    "@types/dompurify": "^3.0.5",
    "@types/qrcode": "^1.5.6",
    "@zxing/browser": "^0.1.4",
    "@zxing/library": "^0.21.3",
    "@zxing/ngx-scanner": "^19.0.0",
    "chart.js": "^4.5.1",
    "dompurify": "^3.2.3",
    "marked": "^14.1.3",
    "ng2-charts": "^8.0.0",
    "qrcode": "^1.5.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.26",
    "@angular-eslint/builder": "^19.0.0",
    "@angular-eslint/eslint-plugin": "^19.0.0",
    "@angular-eslint/eslint-plugin-template": "^19.0.0",
    "@angular-eslint/schematics": "^19.0.0",
    "@angular-eslint/template-parser": "^19.0.0",
    "@angular/cli": "~19.2.19",
    "@angular/compiler-cli": "~19.2.19",
    "@playwright/test": "^1.49.1",
    "@lhci/cli": "^0.14.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/jasmine": "~5.1.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.5.15",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.18.0"
  },
  "overrides": {
    "@angular/animations": "~19.2.19",
    "@angular/cdk": "~19.2.19",
    "@angular/common": "~19.2.19",
    "@angular/compiler": "~19.2.19",
    "@angular/core": "~19.2.19",
    "@angular/forms": "~19.2.19",
    "@angular/platform-browser": "~19.2.19",
    "@angular/platform-browser-dynamic": "~19.2.19",
    "@angular/router": "~19.2.19",
    "@angular/compiler-cli": "~19.2.19"
  }
}
